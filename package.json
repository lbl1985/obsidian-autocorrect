{
  "name": "obsidian-autocorrect",
  "version": "1.0.1",
  "description": "Autocorrect plugin for Obsidian - automatically corrects common spelling mistakes as you type",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "jest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "autocorrect",
    "spellcheck",
    "spelling"
  ],
  "author": "Binlong",
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^obsidian$": "<rootDir>/tests/__mocks__/obsidian.ts",
      "^@codemirror/(.*)$": "<rootDir>/tests/__mocks__/codemirror.ts",
      "^nspell$": "<rootDir>/tests/__mocks__/nspell.ts",
      "dictionary-en/index\\.aff$": "<rootDir>/tests/__mocks__/empty-string.ts",
      "dictionary-en/index\\.dic$": "<rootDir>/tests/__mocks__/empty-string.ts"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs"
          }
        }
      ]
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/__mocks__/"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^16.11.6",
    "esbuild": "0.17.3",
    "jest": "^30.3.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "dictionary-en": "^4.0.0",
    "nspell": "^2.1.5"
  }
}
